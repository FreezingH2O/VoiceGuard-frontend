# true (default): everything runs on the in-memory mock layer.
# false: auth, calls, the Live Detector Test upload, and guardian alert reads hit
# the real backend below; everything else stays mocked (see src/services/api.ts).
VITE_USE_MOCKS=true

# Real backend base URL (REST). WebSocket URLs are returned by POST /calls.
VITE_API_URL=http://localhost:8000
